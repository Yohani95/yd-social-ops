# ============================================================
# YD Social Ops — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://tu-dominio.cl
APP_URL=https://tu-dominio.cl
NODE_ENV=development

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------------------------------------------------------------
# Cifrado (AES-256 para tokens OAuth)
# Genera con: openssl rand -hex 32
# ------------------------------------------------------------
ENCRYPTION_KEY=your_32_byte_hex_string_here

# ------------------------------------------------------------
# AI Providers
# Proveedor primario: groq | gemini | openai
# ------------------------------------------------------------
AI_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_OUTPUT_TOKENS=1024
GROQ_MODEL_COOLDOWN_MS=1000

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=sk-...

AI_CHAT_HISTORY_LIMIT=10
AI_RATE_LIMIT_PER_MINUTE=60
AI_MAX_OUTPUT_TOKENS=1024
# AI_FORCE_ALL_TOOLS=true

# ------------------------------------------------------------
# Meta (Facebook / Instagram / WhatsApp)
# ------------------------------------------------------------
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
NEXT_PUBLIC_META_APP_ID=your_meta_app_id

# Meta Pixel (solo producción)
NEXT_PUBLIC_META_PIXEL_ENABLED=false
NEXT_PUBLIC_META_PIXEL_ID=

# ------------------------------------------------------------
# Mercado Pago
# ------------------------------------------------------------
MP_CLIENT_ID=your_mp_client_id
MP_CLIENT_SECRET=your_mp_client_secret
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=your_mp_webhook_secret
NEXT_PUBLIC_MP_CLIENT_ID=your_mp_client_id

# Modo de suscripción: plan_checkout | api_preapproval
MP_SAAS_SUBSCRIBE_MODE=plan_checkout

# URL base para callback post-pago
MP_SAAS_BACK_URL_BASE=https://tu-dominio.cl

# IDs de preapproval plans (creados con script mp:plans:reset)
MP_PREAPPROVAL_PLAN_BASIC=
MP_PREAPPROVAL_PLAN_PRO=
MP_PREAPPROVAL_PLAN_BUSINESS=
MP_PREAPPROVAL_PLAN_ENTERPRISE=
MP_PREAPPROVAL_PLAN_ENTERPRISE_PLUS=

# Planes sin trial
MP_PREAPPROVAL_PLAN_BASIC_NO_TRIAL=
MP_PREAPPROVAL_PLAN_PRO_NO_TRIAL=
MP_PREAPPROVAL_PLAN_BUSINESS_NO_TRIAL=
MP_PREAPPROVAL_PLAN_ENTERPRISE_NO_TRIAL=
MP_PREAPPROVAL_PLAN_ENTERPRISE_PLUS_NO_TRIAL=

# Links de checkout por plan
MP_PLAN_BASIC_LINK=
MP_PLAN_PRO_LINK=
MP_PLAN_BUSINESS_LINK=
MP_PLAN_ENTERPRISE_LINK=
MP_PLAN_ENTERPRISE_PLUS_LINK=

MP_PLAN_BASIC_LINK_NO_TRIAL=
MP_PLAN_PRO_LINK_NO_TRIAL=
MP_PLAN_BUSINESS_LINK_NO_TRIAL=
MP_PLAN_ENTERPRISE_LINK_NO_TRIAL=
MP_PLAN_ENTERPRISE_PLUS_LINK_NO_TRIAL=

# Precios por plan (CLP, sin puntos)
MP_SAAS_PLAN_AMOUNT_BASIC=9990
MP_SAAS_PLAN_AMOUNT_PRO=24990
MP_SAAS_PLAN_AMOUNT_BUSINESS=49990
MP_SAAS_PLAN_AMOUNT_ENTERPRISE=79990
MP_SAAS_PLAN_AMOUNT_ENTERPRISE_PLUS=199990

# Dev/sandbox
# MP_FORCE_SANDBOX_PAYER_EMAIL=test_user@test.com
# MP_SANDBOX_PAYER_EMAIL=test_user@test.com

# Idempotencia para links ad-hoc (minutos)
MERCHANT_AD_HOC_IDEMPOTENCY_MINUTES=5

# ------------------------------------------------------------
# Email transaccional
# Resend (recomendado) o SMTP / Gmail OAuth
# ------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@tu-dominio.cl
# Secret para verificar webhooks de Resend Inbound (Svix)
RESEND_INBOUND_WEBHOOK_SECRET=whsec_...

# Calendly (integración de agendamiento — OAuth 2.0)
# ------------------------------------------------------------
CALENDLY_CLIENT_ID=MJGEIdV0oaibMwdfKLITr_Iuq2AjznngVdXEzHjPdog
CALENDLY_CLIENT_SECRET=rYE9Wp-6NXRFp12SayyhGX3ISEuPEQRCAf_jX7SJg7U
CALENDLY_REDIRECT_URI=https://social.yd-engineering.cl/api/integrations/calendly/callback
CALENDLY_WEBHOOK_SIGNING_KEY=Ik3qyZSup6xFtxzdd40nnenN39xjcgx8Cm_l9zyNDj8

# Funcionalidades opcionales de email
COLD_LEADS_EMAIL_ENABLED=false
OWNER_ALERTS_EMAIL_ENABLED=false

# ------------------------------------------------------------
# Google OAuth (para integración de email Gmail)
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ------------------------------------------------------------
# Cron jobs
# Secret para autenticar llamadas desde Vercel Cron
# ------------------------------------------------------------
CRON_SECRET=your_cron_secret_here

# ------------------------------------------------------------
# Retención de datos (días, 0 = no archivar)
# ------------------------------------------------------------
PAYMENT_EVENTS_RETENTION_DAYS=365
CHAT_LOGS_RETENTION_DAYS=180
INBOX_MESSAGES_RETENTION_DAYS=180
INBOX_THREADS_RETENTION_DAYS=365

# Bucket de Supabase Storage para archivos
ARCHIVE_BUCKET=archives

# ------------------------------------------------------------
# Cola de eventos (Upstash Redis — opcional)
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
EVENT_QUEUE_KEY=event_queue
EVENT_QUEUE_DLQ_KEY=event_queue_dlq

# ------------------------------------------------------------
# Desarrollo local
# ------------------------------------------------------------
# Ngrok para recibir webhooks en local
# NGROK_URL=https://xxxx.ngrok.io

# n8n (automatizaciones opcionales)
# N8N_WEBHOOK_URL=
